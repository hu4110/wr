<!DOCTYPE html>
<html lang="zh-TW">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
<title>寫作工作室 - 筆記與長圖輸出</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Noto+Serif+TC:wght@300;400;500;700&family=Noto+Sans+TC:wght@300;400;500;700&display=swap');

  :root {
    --app-bg: #f5f0e8;
    --sidebar-bg: #2c2420;
    --sidebar-hover: #3d3028;
    --sidebar-text: #e8d5b7;
    --text-main: #1a1410;
    --text-muted: #8a7a68;
    --border: #d4c4a8;
    --accent: #8b4513;
    --accent-light: #c4956a;
    --export-bg: #1a1814;
    --export-panel: #242018;
    --export-text: #e8dfc8;
    --export-border: #3d3628;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; -webkit-tap-highlight-color: transparent; }

  body {
    font-family: 'Noto Sans TC', sans-serif;
    background: var(--app-bg);
    color: var(--text-main);
    display: flex;
    height: 100vh;
    height: 100dvh;
    overflow: hidden;
  }

  #sidebar {
    width: 280px;
    background: var(--sidebar-bg);
    color: var(--sidebar-text);
    display: flex;
    flex-direction: column;
    flex-shrink: 0;
    overflow: hidden;
    transition: width 0.3s ease;
    z-index: 50;
  }
  #sidebar.collapsed { width: 0; }

  .sidebar-header {
    padding: 20px;
    border-bottom: 1px solid var(--sidebar-hover);
    display: flex;
    justify-content: space-between;
    align-items: center;
    min-width: 280px;
  }
  .sidebar-header h1 { font-size: 18px; font-weight: 500; letter-spacing: 1px; }

  .btn-new {
    background: transparent;
    border: 1px solid var(--sidebar-text);
    color: var(--sidebar-text);
    padding: 6px 12px;
    border-radius: 4px;
    cursor: pointer;
    font-size: 13px;
    transition: all 0.2s;
    white-space: nowrap;
  }
  .btn-new:hover { background: var(--sidebar-text); color: var(--sidebar-bg); }

  #note-list { flex: 1; overflow-y: auto; padding: 10px; min-width: 280px; }

  .note-item {
    padding: 15px;
    border-radius: 8px;
    cursor: pointer;
    margin-bottom: 5px;
    transition: background 0.2s;
  }
  .note-item:hover { background: var(--sidebar-hover); }
  .note-item.active { background: var(--sidebar-hover); border-left: 3px solid var(--accent-light); }
  .note-title   { font-size: 15px; font-weight: 500; margin-bottom: 4px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .note-preview { font-size: 12px; color: #a09585; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .note-date    { font-size: 11px; color: #7a6f5d; margin-top: 6px; }

  #sidebar-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.45);
    z-index: 49;
  }

  @media (max-width: 768px) {
    #sidebar {
      position: fixed;
      left: 0; top: 0;
      height: 100%;
      width: 280px !important;
      transform: translateX(-100%);
      transition: transform 0.3s ease;
      overflow: visible;
    }
    #sidebar.show { transform: translateX(0); }
    #sidebar.collapsed { transform: translateX(-100%); }
  }

  #main {
    flex: 1;
    display: flex;
    flex-direction: column;
    position: relative;
    background: var(--app-bg);
    min-width: 0;
  }

  #toolbar {
    padding: 10px 16px;
    background: var(--app-bg);
    border-bottom: 1px solid var(--border);
    display: flex;
    gap: 12px;
    align-items: center;
    flex-wrap: nowrap;
    overflow-x: auto;
    white-space: nowrap;
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
  #toolbar::-webkit-scrollbar { display: none; }

  #menu-toggle-btn {
    background: transparent;
    border: none;
    color: var(--text-main);
    width: 34px; height: 34px;
    border-radius: 6px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: background 0.2s;
  }
  #menu-toggle-btn:hover { background: rgba(139, 69, 19, 0.1); }
  #menu-toggle-btn svg { width: 20px; height: 20px; fill: currentColor; }

  .toolbar-group {
    display: flex;
    align-items: center;
    gap: 4px;
    border-right: 1px solid var(--border);
    padding-right: 12px;
  }
  .toolbar-group:last-child { border-right: none; padding-right: 0; }

  .tool-btn {
    background: transparent;
    border: none;
    color: var(--text-main);
    width: 34px; height: 34px;
    border-radius: 6px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s;
  }
  .tool-btn:hover { background: rgba(139, 69, 19, 0.1); }
  .tool-btn svg { width: 18px; height: 18px; fill: currentColor; }

  select.tool-select {
    background: transparent;
    border: 1px solid var(--border);
    padding: 6px 8px;
    border-radius: 4px;
    color: var(--text-main);
    font-family: inherit;
    font-size: 14px;
    outline: none;
    cursor: pointer;
  }

  .btn-io {
    background: transparent;
    border: 1px solid var(--border);
    color: var(--text-main);
    padding: 6px 10px;
    border-radius: 6px;
    cursor: pointer;
    font-size: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 5px;
    transition: all 0.2s;
    white-space: nowrap;
    height: 34px;
    flex-shrink: 0;
  }
  .btn-io:hover { background: rgba(139, 69, 19, 0.1); }
  .btn-io svg { width: 15px; height: 15px; fill: currentColor; flex-shrink: 0; }
  @media (max-width: 768px) {
    .btn-io .io-label { display: none; }
    .btn-io { padding: 6px 8px; }
    .btn-export span { display: none; }
  }

  .btn-export {
    margin-left: auto;
    background: var(--accent);
    color: white;
    border: none;
    padding: 8px 16px;
    border-radius: 20px;
    font-size: 14px;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 6px;
    transition: background 0.2s;
    flex-shrink: 0;
  }
  .btn-export:hover { background: #6b340e; }

  #editor-container {
    flex: 1;
    overflow-y: auto;
    padding: 40px;
    display: flex;
    justify-content: center;
  }
  @media (max-width: 768px) { #editor-container { padding: 20px; } }

  #editor {
    width: 100%;
    max-width: 800px;
    min-height: 100%;
    outline: none;
    font-size: 16px;
    line-height: 1.8;
    color: var(--text-main);
    font-family: 'Noto Sans TC', sans-serif;
    text-align: left;
    transition: text-align 0.3s;
    padding-bottom: 50vh;
  }

  #editor b, #editor strong { font-weight: bold; }
  #editor i, #editor em { font-style: italic; }
  #editor blockquote {
    border-left: 4px solid var(--accent);
    padding: 6px 0 6px 16px;
    margin: 12px 0;
    color: var(--text-muted);
    background: rgba(139, 69, 19, 0.05);
    border-radius: 0 4px 4px 0;
  }
  #editor font[size="2"] { font-size: 14px; }
  #editor font[size="3"] { font-size: 16px; }
  #editor font[size="4"] { font-size: 18px; }
  #editor font[size="5"] { font-size: 24px; }
  #editor font[size="6"] { font-size: 32px; }
  #editor[data-placeholder]:empty:before {
    content: attr(data-placeholder);
    color: var(--text-muted);
    opacity: 0.6;
    pointer-events: none;
  }

  #statusbar {
    height: 32px;
    padding: 0 20px;
    background: var(--app-bg);
    border-top: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-size: 12px;
    color: var(--text-muted);
    flex-shrink: 0;
    user-select: none;
  }
  #statusbar .stat-group { display: flex; gap: 16px; align-items: center; }
  @media (max-width: 768px) {
    #statusbar .stat-group span:not(:first-child) { display: none; }
  }

  #save-indicator {
    display: flex;
    align-items: center;
    gap: 5px;
    font-size: 12px;
    color: var(--text-muted);
    transition: color 0.3s;
  }
  #save-indicator.saving { color: var(--accent-light); }
  #save-indicator.saved  { color: #5a9a5a; }
  #save-dot { width: 7px; height: 7px; border-radius: 50%; background: currentColor; flex-shrink: 0; }

  /* ── 長圖輸出 Modal ─────────────────────────────────── */
  #export-modal {
    position: fixed;
    top: 0; left: 0; width: 100%; height: 100%;
    background: var(--export-bg);
    color: var(--export-text);
    z-index: 100;
    display: none;
    flex-direction: row;
  }
  #export-settings {
    width: 340px;
    background: var(--export-panel);
    border-right: 1px solid var(--export-border);
    padding: 24px;
    overflow-y: auto;
    display: flex;
    flex-direction: column;
    gap: 20px;
    flex-shrink: 0;
  }
  .export-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-bottom: 1px solid var(--export-border);
    padding-bottom: 15px;
  }
  .export-header h2 { font-size: 18px; font-weight: 500; }
  .btn-close { background: transparent; border: none; color: var(--export-text); font-size: 28px; cursor: pointer; }

  .setting-group { display: flex; flex-direction: column; gap: 8px; }
  .setting-group label { font-size: 13px; color: #9a9080; }
  .setting-group input, .setting-group select {
    background: var(--export-bg);
    border: 1px solid var(--export-border);
    color: var(--export-text);
    padding: 10px 12px;
    border-radius: 6px;
    font-size: 14px;
    outline: none;
    width: 100%;
  }
  .setting-row { display: flex; gap: 12px; }
  .setting-row > div { flex: 1; min-width: 0; }

  .btn-download {
    background: var(--accent);
    color: white;
    border: none;
    padding: 14px;
    border-radius: 8px;
    font-size: 15px;
    cursor: pointer;
    font-weight: 500;
    text-align: center;
    margin-top: 10px;
    transition: background 0.2s;
  }
  .btn-download:hover { background: #6b340e; }

  #export-preview-container {
    flex: 1;
    overflow-y: auto;
    padding: 40px 20px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px;
    background: #111;
  }
  .preview-img {
    max-width: 100%;
    height: auto;
    box-shadow: 0 10px 30px rgba(0,0,0,0.5);
    border-radius: 4px;
  }

  @media (max-width: 768px) {
    #export-modal { flex-direction: column; }
    #export-settings { width: 100%; border-right: none; border-bottom: 1px solid var(--export-border); max-height: 50vh; }
    #export-preview-container { padding: 20px; }
  }

  #toast {
    position: fixed;
    bottom: 60px;
    left: 50%;
    transform: translateX(-50%) translateY(20px);
    background: #2c2420;
    color: #e8d5b7;
    padding: 10px 20px;
    border-radius: 8px;
    font-size: 13px;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s, transform 0.3s;
    z-index: 999;
    white-space: nowrap;
  }
  #toast.show { opacity: 1; transform: translateX(-50%) translateY(0); }

  #render-canvas { display: none; }
  #file-upload-input { display: none; }
</style>
</head>
<body>

<div id="sidebar-overlay" onclick="closeSidebarMobile()"></div>

<aside id="sidebar">
  <div class="sidebar-header">
    <h1>工作室</h1>
    <button class="btn-new" onclick="createNewNote()">+ 新增</button>
  </div>
  <div id="note-list"></div>
</aside>

<input type="file" id="file-upload-input" accept=".json" onchange="uploadProgress(event)">

<main id="main">
  <div id="toolbar">
    <button id="menu-toggle-btn" onclick="toggleSidebar()" onmousedown="event.preventDefault()" ontouchstart="event.preventDefault()" title="開啟 / 收起側邊欄">
      <svg viewBox="0 0 24 24"><path d="M3 18h18v-2H3v2zm0-5h18v-2H3v2zm0-7v2h18V6H3z"/></svg>
    </button>

    <div class="toolbar-group">
      <select class="tool-select" id="fontFamilySelect" onchange="execCmd('fontName', this.value)">
        <option value="Noto Sans TC">黑體</option>
        <option value="Noto Serif TC">宋體</option>
      </select>
      <select class="tool-select" id="fontSizeSelect" onchange="execCmd('fontSize', this.value)">
        <option value="2">小</option>
        <option value="3" selected>中 (標準)</option>
        <option value="4">大</option>
        <option value="5">特大</option>
        <option value="6">標題</option>
      </select>
    </div>

    <div class="toolbar-group">
      <button class="tool-btn" onclick="execCmd('bold')" onmousedown="event.preventDefault()" ontouchstart="event.preventDefault()" title="粗體">
        <svg viewBox="0 0 24 24"><path d="M15.6 10.79c.97-.67 1.65-1.77 1.65-2.79 0-2.26-1.75-4-4-4H7v14h7.04c2.09 0 3.71-1.7 3.71-3.79 0-1.52-.86-2.82-2.15-3.42zM10 6.5h3c.83 0 1.5.67 1.5 1.5s-.67 1.5-1.5 1.5h-3v-3zm3.5 9H10v-3h3.5c.83 0 1.5.67 1.5 1.5s-.67 1.5-1.5 1.5z"/></svg>
      </button>
      <button class="tool-btn" onclick="execCmd('italic')" onmousedown="event.preventDefault()" ontouchstart="event.preventDefault()" title="斜體">
        <svg viewBox="0 0 24 24"><path d="M10 4v3h2.21l-3.42 8H6v3h8v-3h-2.21l3.42-8H18V4z"/></svg>
      </button>
      <button class="tool-btn" onclick="toggleQuote()" onmousedown="event.preventDefault()" ontouchstart="event.preventDefault()" title="引用區塊">
        <svg viewBox="0 0 24 24"><path d="M6 17h3l2-4V7H5v6h3zm8 0h3l2-4V7h-6v6h3z"/></svg>
      </button>
    </div>

    <div class="toolbar-group">
      <button class="tool-btn" onclick="insertIndent()" onmousedown="event.preventDefault()" ontouchstart="event.preventDefault()" title="縮排">
        <svg viewBox="0 0 24 24"><path d="M3 21h18v-2H3v2zM3 8v8l4-4-4-4zm8 9h10v-2H11v2zm0-4h10v-2H11v2zm0-4h10V7H11v2zM3 3v2h18V3H3z"/></svg>
      </button>
    </div>

    <div class="toolbar-group">
      <button class="tool-btn" onclick="execCmd('justifyLeft')" onmousedown="event.preventDefault()" ontouchstart="event.preventDefault()" title="靠左">
        <svg viewBox="0 0 24 24"><path d="M15 15H3v2h12v-2zm0-8H3v2h12V7zM3 13h18v-2H3v2zm0 8h18v-2H3v2zM3 3v2h18V3H3z"/></svg>
      </button>
      <button class="tool-btn" onclick="execCmd('justifyCenter')" onmousedown="event.preventDefault()" ontouchstart="event.preventDefault()" title="置中">
        <svg viewBox="0 0 24 24"><path d="M7 15v2h10v-2H7zm-4 6h18v-2H3v2zm0-8h18v-2H3v2zm4-6v2h10V7H7zM3 3v2h18V3H3z"/></svg>
      </button>
      <button class="tool-btn" onclick="execCmd('justifyRight')" onmousedown="event.preventDefault()" ontouchstart="event.preventDefault()" title="靠右">
        <svg viewBox="0 0 24 24"><path d="M3 21h18v-2H3v2zm6-4h12v-2H9v2zm-6-4h18v-2H3v2zm6-4h12V7H9v2zM3 3v2h18V3H3z"/></svg>
      </button>
    </div>

    <div class="toolbar-group">
      <button class="tool-btn" style="color:var(--accent);" onclick="setGlobalAlign('left')" onmousedown="event.preventDefault()" ontouchstart="event.preventDefault()" title="全文靠左">
        <svg viewBox="0 0 24 24"><path d="M3 3h18v2H3V3zm0 4h14v2H3V7zm0 4h18v2H3v-2zm0 4h14v2H3v-2zm0 4h18v2H3v-2z"/></svg>
      </button>
      <button class="tool-btn" style="color:var(--accent);" onclick="setGlobalAlign('center')" onmousedown="event.preventDefault()" ontouchstart="event.preventDefault()" title="全文置中">
        <svg viewBox="0 0 24 24"><path d="M3 3h18v2H3V3zm4 4h10v2H7V7zm-4 4h18v2H3v-2zm4 4h10v2H7v-2zm-4 4h18v2H3v-2z"/></svg>
      </button>
      <button class="tool-btn" style="color:var(--accent);" onclick="setGlobalAlign('right')" onmousedown="event.preventDefault()" ontouchstart="event.preventDefault()" title="全文靠右">
        <svg viewBox="0 0 24 24"><path d="M3 3h18v2H3V3zm4 4h14v2H7V7zm-4 4h18v2H3v-2zm4 4h14v2H7v-2zm-4 4h18v2H3v-2z"/></svg>
      </button>
    </div>

    <div class="toolbar-group">
      <button class="btn-io" onclick="downloadProgress()" onmousedown="event.preventDefault()" ontouchstart="event.preventDefault()" title="下載進度備份">
        <svg viewBox="0 0 24 24"><path d="M19 9h-4V3H9v6H5l7 7 7-7zM5 18v2h14v-2H5z"/></svg>
        <span class="io-label">下載進度</span>
      </button>
      <button class="btn-io" onclick="triggerUpload()" onmousedown="event.preventDefault()" ontouchstart="event.preventDefault()" title="上傳進度備份">
        <svg viewBox="0 0 24 24"><path d="M9 16h6v-6h4l-7-7-7 7h4v6zm-4 2h14v2H5v-2z"/></svg>
        <span class="io-label">上傳進度</span>
      </button>
    </div>

    <button class="btn-export" onclick="openExportModal()" onmousedown="event.preventDefault()" ontouchstart="event.preventDefault()">
      <svg viewBox="0 0 24 24" style="width:18px;height:18px;fill:currentColor;"><path d="M19 9h-4V3H9v6H5l7 7 7-7zM5 18v2h14v-2H5z"/></svg>
      <span>輸出長圖</span>
    </button>
  </div>

  <div id="editor-container" onclick="focusEditor(event)">
    <div id="editor" contenteditable="true" data-placeholder="開始在此處寫下想法..." oninput="onEditorInput()"></div>
  </div>

  <div id="statusbar">
    <div class="stat-group">
      <span id="word-count">0 字</span>
      <span id="para-count">0 段落</span>
    </div>
    <div id="save-indicator">
      <div id="save-dot"></div>
      <span id="save-text">尚未輸入</span>
    </div>
  </div>
</main>

<!-- 輸出長圖設定面板 -->
<div id="export-modal">
  <div id="export-settings">
    <div class="export-header">
      <h2>輸出長圖設定</h2>
      <button class="btn-close" onclick="closeExportModal()">&times;</button>
    </div>
    <div class="setting-group">
      <label>字體 (統一套用)</label>
      <select id="ex-font" onchange="renderPreview()">
        <option value="Noto Serif TC">宋體 (Serif)</option>
        <option value="Noto Sans TC">黑體 (Sans)</option>
      </select>
    </div>
    <div class="setting-row">
      <div class="setting-group">
        <label>寬度 (px)</label>
        <input type="number" id="ex-width" value="800" onchange="renderPreview()">
      </div>
      <div class="setting-group">
        <label>邊距 (px)</label>
        <input type="number" id="ex-pad" value="60" onchange="renderPreview()">
      </div>
    </div>
    <div class="setting-row">
      <div class="setting-group">
        <label>字體大小</label>
        <input type="number" id="ex-size" value="22" onchange="renderPreview()">
      </div>
      <div class="setting-group">
        <label>行距倍數</label>
        <input type="number" id="ex-lineh" value="1.8" step="0.1" onchange="renderPreview()">
      </div>
    </div>
    <div class="setting-row">
      <div class="setting-group">
        <label>背景顏色</label>
        <input type="color" id="ex-bg" value="#f5f0e8" onchange="renderPreview()">
      </div>
      <div class="setting-group">
        <label>文字顏色</label>
        <input type="color" id="ex-fg" value="#1a1410" onchange="renderPreview()">
      </div>
    </div>
    <div class="setting-group">
      <label>對齊方式 (統一套用)</label>
      <select id="ex-align" onchange="renderPreview()">
        <option value="left">靠左</option>
        <option value="center">置中</option>
        <option value="right">靠右</option>
      </select>
    </div>
    <div class="setting-group">
      <label>浮水印 / 署名</label>
      <input type="text" id="ex-watermark" placeholder="選填" value="@寫作工作室" oninput="renderPreview()">
    </div>
    <div class="setting-group">
      <label>單張圖片最大高度 (超過自動切圖)</label>
      <input type="number" id="ex-sliceh" value="4000" onchange="renderPreview()">
    </div>
    <button class="btn-download" onclick="downloadImages()">下載圖片</button>
  </div>
  <div id="export-preview-container"></div>
</div>

<canvas id="render-canvas"></canvas>
<div id="toast"></div>

<script>
/* =====================================================
    1. 儲存系統
===================================================== */
let notes = [];
let currentNoteId = null;
const editor = document.getElementById('editor');
let autoSaveTimer = null;
let savedRange = null;

document.addEventListener('selectionchange', () => {
  const sel = window.getSelection();
  if (sel && sel.rangeCount > 0) {
    const r = sel.getRangeAt(0);
    if (editor.contains(r.commonAncestorContainer)) {
      savedRange = r.cloneRange();
    }
  }
});

function loadFromLocal() {
  try {
    const saved = localStorage.getItem('mojo_notes_app');
    if (saved) notes = JSON.parse(saved);
  } catch(e) { console.warn('localStorage 不可用'); }
}

function saveToLocal() {
  try { localStorage.setItem('mojo_notes_app', JSON.stringify(notes)); } catch(e) {}
}

function initApp() {
  loadFromLocal();
  if (notes.length === 0) {
    createNewNote(true);
  } else {
    renderNoteList();
    loadNote(notes[0].id);
  }
}

function createNewNote(isFirst = false) {
  const newNote = { id: Date.now().toString(), content: '', align: 'left', date: new Date().toISOString() };
  notes.unshift(newNote);
  saveToLocal();
  renderNoteList();
  loadNote(newNote.id);
  if (!isFirst && window.innerWidth <= 768) closeSidebarMobile();
  setTimeout(() => editor.focus(), 100);
}

function renderNoteList() {
  const list = document.getElementById('note-list');
  list.innerHTML = '';
  notes.forEach(note => {
    const tmpDiv = document.createElement('div');
    tmpDiv.innerHTML = note.content;
    const plain   = tmpDiv.innerText.trim();
    const title   = plain ? plain.split('\n')[0].substring(0, 20) : '無標題筆記';
    const preview = plain ? plain.replace(/\n/g, ' ').substring(0, 30) : '尚未輸入內容...';
    const dateStr = new Date(note.date).toLocaleDateString('zh-TW', { month:'short', day:'numeric', hour:'2-digit', minute:'2-digit' });

    const el = document.createElement('div');
    el.className = `note-item ${note.id === currentNoteId ? 'active' : ''}`;
    el.onclick = () => { loadNote(note.id); if (window.innerWidth <= 768) closeSidebarMobile(); };

    const titleEl   = document.createElement('div'); titleEl.className = 'note-title';   titleEl.textContent = title;
    const previewEl = document.createElement('div'); previewEl.className = 'note-preview'; previewEl.textContent = preview;
    const dateEl    = document.createElement('div'); dateEl.className = 'note-date';    dateEl.textContent = dateStr;
    el.appendChild(titleEl); el.appendChild(previewEl); el.appendChild(dateEl);
    list.appendChild(el);
  });
}

function loadNote(id) {
  currentNoteId = id;
  const note = notes.find(n => n.id === id);
  if (note) {
    editor.innerHTML = note.content;
    editor.style.textAlign = note.align || 'left';
    renderNoteList();
    updateWordCount();
    setSaveStatus('saved');
  }
}

function saveCurrentNote() {
  if (!currentNoteId) return;
  const idx = notes.findIndex(n => n.id === currentNoteId);
  if (idx > -1) {
    notes[idx].content = editor.innerHTML;
    notes[idx].align   = editor.style.textAlign;
    notes[idx].date    = new Date().toISOString();
    saveToLocal();
  }
}

editor.addEventListener('blur', renderNoteList);

/* =====================================================
    2. 側邊欄開關
===================================================== */
function toggleSidebar() {
  const sidebar  = document.getElementById('sidebar');
  const overlay  = document.getElementById('sidebar-overlay');
  const isMobile = window.innerWidth <= 768;
  if (isMobile) {
    const isOpen = sidebar.classList.contains('show');
    if (isOpen) { closeSidebarMobile(); }
    else { sidebar.classList.add('show'); sidebar.classList.remove('collapsed'); overlay.style.display = 'block'; }
  } else {
    sidebar.classList.toggle('collapsed');
  }
}

function closeSidebarMobile() {
  document.getElementById('sidebar').classList.remove('show');
  document.getElementById('sidebar-overlay').style.display = 'none';
}

/* =====================================================
    3. 自動儲存 + 字數統計
===================================================== */
function onEditorInput() {
  updateWordCount();
  triggerAutoSave();
}

function triggerAutoSave() {
  setSaveStatus('saving');
  clearTimeout(autoSaveTimer);
  autoSaveTimer = setTimeout(() => {
    saveCurrentNote();
    renderNoteList();
    setSaveStatus('saved');
  }, 800);
}

function setSaveStatus(state) {
  const el   = document.getElementById('save-indicator');
  const text = document.getElementById('save-text');
  el.className = '';
  el.id = 'save-indicator';
  if (state === 'saving') { el.classList.add('saving'); text.textContent = '儲存中...'; }
  else if (state === 'saved') {
    el.classList.add('saved');
    const t = new Date();
    text.textContent = `已儲存 ${String(t.getHours()).padStart(2,'0')}:${String(t.getMinutes()).padStart(2,'0')}`;
  } else { text.textContent = '尚未輸入'; }
}

function updateWordCount() {
  const raw       = editor.innerText || '';
  const cjk       = (raw.match(/[\u4e00-\u9fff\u3040-\u30ff\uac00-\ud7af]/g) || []).length;
  const latin     = (raw.replace(/[\u4e00-\u9fff\u3040-\u30ff\uac00-\ud7af]/g, ' ').match(/\b\w+\b/g) || []).length;
  const paraCount = raw.split('\n').filter(p => p.trim().length > 0).length;
  document.getElementById('word-count').textContent = `${cjk + latin} 字`;
  document.getElementById('para-count').textContent = `${paraCount} 段落`;
}

/* =====================================================
    4. 富文本編輯器功能
===================================================== */
function execCmd(command, value = null) {
  editor.focus();
  if (savedRange) { const sel = window.getSelection(); sel.removeAllRanges(); sel.addRange(savedRange); }
  document.execCommand(command, false, value);
  triggerAutoSave();
}

function getTopLevelBlock(node) {
  if (!node) return null;
  if (node.nodeType === Node.TEXT_NODE) node = node.parentNode;
  while (node && node.parentNode !== editor) node = node.parentNode;
  return (node && node !== editor) ? node : null;
}

function insertIndent() {
  editor.focus();
  const sel = window.getSelection();
  if ((!sel || sel.rangeCount === 0 || !editor.contains(sel.getRangeAt(0).commonAncestorContainer)) && savedRange) {
    sel.removeAllRanges(); sel.addRange(savedRange);
  }
  if (!sel || sel.rangeCount === 0) return;
  let range = sel.getRangeAt(0);
  const startBlock = getTopLevelBlock(range.startContainer);
  const endBlock   = getTopLevelBlock(range.endContainer);
  const isMultiBlock = !range.collapsed && startBlock && endBlock && startBlock !== endBlock;
  if (isMultiBlock) {
    const children = Array.from(editor.childNodes);
    let inRange = false;
    const blocks = [];
    for (const child of children) {
      if (child === startBlock) inRange = true;
      if (inRange && child.nodeType === Node.ELEMENT_NODE) blocks.push(child);
      if (child === endBlock) break;
    }
    blocks.forEach(block => { const indent = document.createTextNode('\u3000\u3000'); block.insertBefore(indent, block.firstChild); });
  } else {
    const block = startBlock;
    if (block && block.nodeType === Node.ELEMENT_NODE) {
      const indent = document.createTextNode('\u3000\u3000');
      block.insertBefore(indent, block.firstChild);
    } else {
      const indent = document.createTextNode('\u3000\u3000');
      range.insertNode(indent);
      range.setStartAfter(indent); range.collapse(true);
      sel.removeAllRanges(); sel.addRange(range);
    }
  }
  triggerAutoSave(); updateWordCount();
}

function toggleQuote() {
  editor.focus();
  let inQuote = false;
  let node = window.getSelection().anchorNode;
  while (node && node.id !== 'editor') {
    if (node.nodeName === 'BLOCKQUOTE') { inQuote = true; break; }
    node = node.parentNode;
  }
  document.execCommand('formatBlock', false, inQuote ? 'DIV' : 'BLOCKQUOTE');
  triggerAutoSave();
}

function setGlobalAlign(alignment) {
  editor.style.textAlign = alignment;
  triggerAutoSave();
}

function focusEditor(e) {
  if (e.target === document.getElementById('editor-container')) {
    editor.focus();
    if (typeof window.getSelection !== 'undefined') {
      const range = document.createRange();
      range.selectNodeContents(editor);
      range.collapse(false);
      const sel = window.getSelection();
      sel.removeAllRanges(); sel.addRange(range);
    }
  }
}

/* =====================================================
    5. 下載 / 上傳進度
===================================================== */
function downloadProgress() {
  saveCurrentNote();
  const data = JSON.stringify({ version: 1, exportedAt: new Date().toISOString(), notes }, null, 2);
  const blob = new Blob([data], { type: 'application/json' });
  const url  = URL.createObjectURL(blob);
  const a    = document.createElement('a');
  a.download = `寫作工作室備份_${new Date().toISOString().slice(0,10)}.json`;
  a.href = url; a.click(); URL.revokeObjectURL(url);
  showToast('✅ 進度已下載');
}

function triggerUpload() {
  document.getElementById('file-upload-input').value = '';
  document.getElementById('file-upload-input').click();
}

function uploadProgress(event) {
  const file = event.target.files[0];
  if (!file) return;
  const reader = new FileReader();
  reader.onload = (e) => {
    try {
      const data = JSON.parse(e.target.result);
      if (!data.notes || !Array.isArray(data.notes)) throw new Error('格式不正確');
      if (!confirm(`即將載入備份檔，包含 ${data.notes.length} 篇筆記。\n目前的本機進度將被覆蓋，確定嗎？`)) return;
      notes = data.notes; saveToLocal(); renderNoteList();
      if (notes.length > 0) loadNote(notes[0].id);
      showToast(`✅ 已成功載入 ${notes.length} 篇筆記`);
    } catch(err) { showToast('❌ 檔案格式錯誤，請選擇正確的備份 JSON'); }
  };
  reader.readAsText(file);
}

/* =====================================================
    6. 長圖輸出系統
===================================================== */
let generatedImages = [];

/**
 * 將編輯器 DOM 解析為結構化段落陣列。
 *
 * 修正問題：
 *   ① 引用區塊（blockquote）在輸出圖片中完全消失 → 識別為 type:'blockquote'，
 *      畫布渲染時補畫左側色條 + 背景底色 + 斜體
 *   ② 段落斷行、空行消失 → 不再用 innerText 一次取純文字，
 *      改為逐節點遍歷，精確保留每個塊元素與 <br> 所對應的換行
 */
function getEditorSegments() {
  const segments = [];

  /**
   * 遞迴遍歷節點，inheritedBold 記錄祖先是否已有粗體標記。
   * B / STRONG 元素會將 bold=true 傳遞給所有子節點。
   */
  function processNode(node, inheritedBold) {
    inheritedBold = !!inheritedBold;

    // ── 純文字節點 ──────────────────────────────────────
    if (node.nodeType === Node.TEXT_NODE) {
      const text = node.textContent.replace(/^\n+$/, '').trim();
      if (text) segments.push({ type: 'normal', text, bold: inheritedBold });
      return;
    }

    // ── <br> → 空行 ─────────────────────────────────────
    if (node.nodeName === 'BR') {
      segments.push({ type: 'empty', text: '', bold: false });
      return;
    }

    if (node.nodeType !== Node.ELEMENT_NODE) return;

    const tag     = node.nodeName;
    // B / STRONG 將粗體狀態往下傳
    const isBold  = inheritedBold || tag === 'B' || tag === 'STRONG';

    // ── <blockquote> → 引用 ─────────────────────────────
    if (tag === 'BLOCKQUOTE') {
      // 判斷引用內是否含有粗體（整塊引用視為統一樣式）
      const quoteBold = isBold || !!(node.querySelector && node.querySelector('b, strong'));
      const raw   = node.innerText || node.textContent || '';
      const lines = raw.split('\n');
      lines.forEach((line, idx) => {
        if (idx === 0 && line.trim() === '' && lines.length > 1) return;
        segments.push({ type: 'blockquote', text: line, bold: quoteBold });
      });
      return;
    }

    const inner = node.innerHTML || '';

    // 純空行：<div><br></div> 或 <div></div>
    if (inner === '' || inner === '<br>' || inner.trim() === '') {
      segments.push({ type: 'empty', text: '', bold: false });
      return;
    }

    // 若含有巢狀 blockquote，遞迴處理以正確識別引用
    if (node.querySelector && node.querySelector('blockquote')) {
      for (const child of node.childNodes) processNode(child, isBold);
      return;
    }

    // ── 行內格式標籤（B/STRONG/I/EM/SPAN/FONT…）────────
    // 非塊元素：遞迴子節點，傳遞當前 bold 狀態
    const BLOCK_TAGS = new Set(['DIV','P','H1','H2','H3','H4','H5','H6','LI','UL','OL','SECTION','ARTICLE']);
    if (!BLOCK_TAGS.has(tag)) {
      for (const child of node.childNodes) processNode(child, isBold);
      return;
    }

    // ── 一般塊元素 ──────────────────────────────────────
    // 若塊內含有行內粗體子節點，以遞迴方式取得精確 bold 狀態
    const hasInlineBold = !!(node.querySelector && node.querySelector('b, strong'));
    if (hasInlineBold || isBold) {
      // 含粗體標記：遞迴子節點，各行 bold 狀態由子節點決定
      for (const child of node.childNodes) processNode(child, isBold);
      return;
    }

    // 純文字塊：快速路徑，以 innerText 拆行
    const text = node.innerText || node.textContent || '';
    if (!text.trim()) { segments.push({ type: 'empty', text: '', bold: false }); return; }

    const lines = text.split('\n');
    lines.forEach((line, idx) => {
      if (line.trim() === '') {
        if (idx > 0 && idx < lines.length - 1) segments.push({ type: 'empty', text: '', bold: false });
      } else {
        segments.push({ type: 'normal', text: line, bold: false });
      }
    });
  }

  for (const child of editor.childNodes) processNode(child, false);
  return segments;
}

function openExportModal() {
  document.getElementById('export-modal').style.display = 'flex';
  document.getElementById('ex-align').value = editor.style.textAlign || 'left';
  renderPreview();
}

function closeExportModal() {
  document.getElementById('export-modal').style.display = 'none';
}

/* 依 canvas 量測寬度自動換行 */
function wrapText(ctx, text, maxWidth) {
  const lines = [];
  if (!text) { lines.push(''); return lines; }
  let current = '';
  for (let i = 0; i < text.length; i++) {
    const test = current + text[i];
    if (ctx.measureText(test).width > maxWidth && current.length > 0) {
      lines.push(current); current = text[i];
    } else {
      current = test;
    }
  }
  if (current) lines.push(current);
  return lines;
}

/* hex 轉 rgba 輔助（用於引用底色、浮水印等半透明效果） */
function hexToRgba(hex, alpha) {
  const r = parseInt(hex.slice(1, 3), 16);
  const g = parseInt(hex.slice(3, 5), 16);
  const b = parseInt(hex.slice(5, 7), 16);
  return `rgba(${r},${g},${b},${alpha})`;
}

function renderPreview() {
  const container = document.getElementById('export-preview-container');
  container.innerHTML = '<div style="color:#888;margin-top:60px;text-align:center;font-size:14px;">渲染中...</div>';

  setTimeout(() => {
    /* ── 讀取設定 ─────────────────────────────────── */
    const segments  = getEditorSegments();
    const width     = parseInt(document.getElementById('ex-width').value)   || 800;
    const pad       = parseInt(document.getElementById('ex-pad').value)     || 60;
    const fontSize  = parseInt(document.getElementById('ex-size').value)    || 22;
    const fontFam   = document.getElementById('ex-font').value;
    const lineH     = parseFloat(document.getElementById('ex-lineh').value) || 1.8;
    const bg        = document.getElementById('ex-bg').value;
    const fg        = document.getElementById('ex-fg').value;
    const align     = document.getElementById('ex-align').value;
    const watermark = document.getElementById('ex-watermark').value;
    const maxSliceH = parseInt(document.getElementById('ex-sliceh').value)  || 4000;

    const innerW       = width - pad * 2;
    const lineHeightPx = fontSize * lineH;
    const canvas       = document.getElementById('render-canvas');
    const ctx          = canvas.getContext('2d');

    /* 引用區塊視覺常數 */
    const QUOTE_BAR_W  = 5;           // 左側色條寬度(px)
    const QUOTE_GAP    = 14;          // 色條到文字的間距(px)
    const QUOTE_INDENT = QUOTE_BAR_W + QUOTE_GAP;
    const ACCENT       = '#8b4513';   // 與編輯器 CSS 保持一致

    /* ── 將 segments 展開成逐行 renderData ──────────── */
    const renderData = [];
    let totalHeight  = pad;

    segments.forEach(seg => {
      /* 空行 */
      if (seg.type === 'empty') {
        renderData.push({ type: 'empty', text: '', y: totalHeight });
        totalHeight += lineHeightPx;
        return;
      }

      /* 引用行：量測時同步套用 bold，確保斷行位置與繪製一致 */
      if (seg.type === 'blockquote') {
        const availW = innerW - QUOTE_INDENT;
        ctx.font = `${seg.bold ? 'bold ' : ''}italic ${fontSize}px "${fontFam}"`;
        const lines = wrapText(ctx, seg.text, availW);
        const rows  = lines.length > 0 ? lines : [''];
        rows.forEach(line => {
          renderData.push({ type: 'blockquote', text: line, bold: !!seg.bold, y: totalHeight });
          totalHeight += lineHeightPx;
        });
        return;
      }

      /* 普通段落：量測時同步套用 bold */
      ctx.font = `${seg.bold ? 'bold ' : ''}${fontSize}px "${fontFam}"`;
      const lines = wrapText(ctx, seg.text, innerW);
      const rows  = lines.length > 0 ? lines : [''];
      rows.forEach(line => {
        renderData.push({ type: 'normal', text: line, bold: !!seg.bold, y: totalHeight });
        totalHeight += lineHeightPx;
      });
    });

    totalHeight += pad;
    if (watermark) totalHeight += 50;

    /* ── 計算安全切圖斷點 ────────────────────────────── */
    const sliceBreaks = [0];
    let searchFrom = 0;
    while (true) {
      const target = searchFrom + maxSliceH;
      if (target >= totalHeight) break;
      let safeCut = searchFrom + lineHeightPx;
      for (let i = 0; i < renderData.length; i++) {
        const lineBottom = renderData[i].y + lineHeightPx;
        if (lineBottom <= target) safeCut = lineBottom;
        else break;
      }
      if (safeCut <= searchFrom) safeCut = target;
      sliceBreaks.push(safeCut);
      searchFrom = safeCut;
    }
    sliceBreaks.push(totalHeight);

    generatedImages = [];
    container.innerHTML = '';

    const vMargin = lineHeightPx; // 每張切圖上下留一行的空白

    /* ── 逐張繪製 canvas ─────────────────────────────── */
    for (let s = 0; s < sliceBreaks.length - 1; s++) {
      const sliceTop    = sliceBreaks[s];
      const sliceBottom = sliceBreaks[s + 1];
      const sliceH      = Math.ceil(sliceBottom - sliceTop);

      canvas.width  = width;
      canvas.height = sliceH + vMargin * 2;

      /* 背景填滿 */
      ctx.fillStyle = bg;
      ctx.fillRect(0, 0, width, canvas.height);

      ctx.textBaseline = 'top';

      renderData.forEach(item => {
        const drawY = item.y - sliceTop + vMargin;

        // 超出本片段範圍跳過
        if (drawY + lineHeightPx < vMargin || drawY > sliceH + vMargin) return;

        /* ── 引用區塊 ── */
        if (item.type === 'blockquote') {
          // ① 背景底色（暖色半透明）
          ctx.fillStyle = hexToRgba(ACCENT, 0.06);
          ctx.fillRect(pad, drawY, innerW, lineHeightPx);

          // ② 左側色條（每行都畫，形成視覺連續線）
          ctx.fillStyle = ACCENT;
          ctx.fillRect(pad, drawY, QUOTE_BAR_W, lineHeightPx);

          // ③ 引用文字：斜體（若有粗體則加 bold）+ 略透明
          if (item.text) {
            ctx.fillStyle = hexToRgba(fg, 0.60);
            ctx.font = `${item.bold ? 'bold ' : ''}italic ${fontSize}px "${fontFam}"`;
            if (align === 'center') {
              ctx.textAlign = 'center';
              ctx.fillText(item.text, width / 2, drawY);
            } else if (align === 'right') {
              ctx.textAlign = 'right';
              ctx.fillText(item.text, width - pad, drawY);
            } else {
              ctx.textAlign = 'left';
              ctx.fillText(item.text, pad + QUOTE_INDENT, drawY);
            }
          }

        /* ── 一般文字 ── */
        } else if (item.type === 'normal' && item.text) {
          ctx.fillStyle = fg;
          ctx.font = `${item.bold ? 'bold ' : ''}${fontSize}px "${fontFam}"`;
          if (align === 'center') {
            ctx.textAlign = 'center';
            ctx.fillText(item.text, width / 2, drawY);
          } else if (align === 'right') {
            ctx.textAlign = 'right';
            ctx.fillText(item.text, width - pad, drawY);
          } else {
            ctx.textAlign = 'left';
            ctx.fillText(item.text, pad, drawY);
          }
        }
        /* empty 型別不繪製，僅保留高度留白 */
      });

      /* 浮水印（最後一張） */
      if (watermark && s === sliceBreaks.length - 2) {
        ctx.fillStyle    = hexToRgba(fg, 0.36);
        ctx.font         = `14px "${fontFam}"`;
        ctx.textBaseline = 'bottom';
        ctx.textAlign    = 'right';
        ctx.fillText(watermark, width - pad, canvas.height - 20);
      }

      const dataUrl = canvas.toDataURL('image/png');
      generatedImages.push(dataUrl);

      const imgEl = document.createElement('img');
      imgEl.src   = dataUrl;
      imgEl.className = 'preview-img';
      container.appendChild(imgEl);
    }
  }, 50);
}

function downloadImages() {
  if (generatedImages.length === 0) return;
  const btn = document.querySelector('.btn-download');
  btn.textContent = '準備下載...';
  let delay = 0;
  generatedImages.forEach((img, i) => {
    setTimeout(() => {
      const link = document.createElement('a');
      link.download = `筆記輸出_${i + 1}.png`;
      link.href = img; link.click();
      if (i === generatedImages.length - 1) btn.textContent = '下載圖片';
    }, delay);
    delay += 300;
  });
}

/* =====================================================
    7. Toast
===================================================== */
let toastTimer = null;
function showToast(msg) {
  const el = document.getElementById('toast');
  el.textContent = msg;
  el.classList.add('show');
  clearTimeout(toastTimer);
  toastTimer = setTimeout(() => el.classList.remove('show'), 2500);
}

window.addEventListener('DOMContentLoaded', initApp);
